# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# macOS
.DS_Store

# Windows download markers (illegal ':' in NTFS filenames)
*:Zone.Identifier

# LaTeX build outputs
*.aux
*.log
*.out
*.fls
*.fdb_latexmk
*.synctex.gz

# Archived external tools (1.8GB, not tracked)
_archive/external-tools/
_archive/misc/

# Model checkpoints are tracked, but large experiment re-runs are not
*.tmp
